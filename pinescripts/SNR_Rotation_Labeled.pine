//@version=5
indicator("SNR Rotation Labeled", overlay=true, max_labels_count=500)

// ATR Period
atrPeriod = input.int(14, "ATR Period", minval=1)
atrMultiplier = input.float(1.0, "ATR Multiplier", step=0.1)
lookback = input.int(50, "Lookback (candles)", minval=10)

// Colors
colorRes := input.color(color.new(#ef4444, 0), "Resistance Color")
colorSup := input.color(color.new(#10b981, 0), "Support Color")
colorNeutral := input.color(color.new(#f59e0b, 0), "Neutral Color")

// Compute ATR
tr1 = high - low
tr2 = math.abs(high - close[1])
tr3 = math.abs(low - close[1])
tr = math.max(tr1, math.max(tr2, tr3))
atr = ta.sma(tr, atrPeriod)

// Find swing highs and lows
swingHigh(val, len) =>
    ret = true
    for i = 1 to len
        if high[i] > val
            ret := false
            break
    ret

swingLow(val, len) =>
    ret = true
    for i = 1 to len
        if low[i] < val
            ret := false
            break
    ret

// Track levels
var float[] resLevels = array.new_float()
var float[] supLevels = array.new_float()
var int[] resBars = array.new_int()
var int[] supBars = array.new_int()

// Add new swing high
if swingHigh(high, 5) and high > 0
    array.push(resLevels, high)
    array.push(resBars, bar_index)

// Add new swing low
if swingLow(low, 5) and low > 0
    array.push(supLevels, low)
    array.push(supBars, bar_index)

// Keep only recent levels
if array.size(resLevels) > 20
    array.shift(resLevels)
    array.shift(resBars)
if array.size(supLevels) > 20
    array.shift(supLevels)
    array.shift(supBars)

// Filter levels that are too close
filteredRes = array.new_float()
filteredResBars = array.new_int()
filteredSup = array.new_float()
filteredSupBars = array.new_int()

for i = 0 to array.size(resLevels) - 1
    val = array.get(resLevels, i)
    bar = array.get(resBars, i)
    tooClose = false
    for j = 0 to array.size(filteredRes) - 1
        if math.abs(val - array.get(filteredRes, j)) < atr * 0.5
            tooClose := true
            break
    if not tooClose
        array.push(filteredRes, val)
        array.push(filteredResBars, bar)

for i = 0 to array.size(supLevels) - 1
    val = array.get(supLevels, i)
    bar = array.get(supBars, i)
    tooClose = false
    for j = 0 to array.size(filteredSup) - 1
        if math.abs(val - array.get(filteredSup, j)) < atr * 0.5
            tooClose := true
            break
    if not tooClose
        array.push(filteredSup, val)
        array.push(filteredSupBars, bar)

// Draw resistance levels
for i = 0 to array.size(filteredRes) - 1
    lvl = array.get(filteredRes, i)
    bar = array.get(filteredResBars, i)
    dist = (high - lvl) / atr
    line.new(bar, lvl, bar_index, lvl, color=colorRes, width=1, extend=extend.right)
    label.new(math.max(bar, bar_index - 20), lvl, str.tostring(lvl, "#.##") + "  (" + str.tostring(dist, "#.#") + "x)", 
             style=label.style_label_lower, color=colorRes, textcolor=color.white, size=size.tiny)

// Draw support levels
for i = 0 to array.size(filteredSup) - 1
    lvl = array.get(filteredSup, i)
    bar = array.get(filteredSupBars, i)
    dist = (lvl - low) / atr
    line.new(bar, lvl, bar_index, lvl, color=colorSup, width=1, extend=extend.right)
    label.new(math.max(bar, bar_index - 20), lvl, str.tostring(lvl, "#.##") + "  (" + str.tostring(dist, "#.#") + "x)", 
             style=label.style_label_upper, color=colorSup, textcolor=color.white, size=size.tiny)

// Current price line
cp = close
line.new(bar_index - 100, cp, bar_index, cp, color=colorNeutral, width=2, style=line.style_dashed)
label.new(bar_index - 99, cp, "PRICE: " + str.tostring(cp, "#.##"), 
         style=label.style_label_right, color=colorNeutral, textcolor=color.white, size=size.small)

// Dashboard
var table dash = table.new(position.top_right, 2, 4, bgcolor=color.new(#0a0e17, 10), border_width=1)
if barstate.islast
    table.cell(dash, 0, 0, "Level", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 0, "Dist (ATR)", text_color=color.white, text_size=size.tiny)
    // Nearest resistance
    nearestRes = array.size(filteredRes) > 0 ? array.get(filteredRes, array.size(filteredRes) - 1) : na
    if not na(nearestRes)
        distR = (nearestRes - close) / atr
        table.cell(dash, 0, 1, "R: " + str.tostring(nearestRes, "#.##"), text_color=colorRes, text_size=size.tiny)
        table.cell(dash, 1, 1, str.tostring(distR, "#.#"), text_color=distR < 0.5 ? color.new(colorRes, 0) : color.white, text_size=size.tiny)
    // Nearest support
    nearestSup = array.size(filteredSup) > 0 ? array.get(filteredSup, array.size(filteredSup) - 1) : na
    if not na(nearestSup)
        distS = (close - nearestSup) / atr
        table.cell(dash, 0, 2, "S: " + str.tostring(nearestSup, "#.##"), text_color=colorSup, text_size=size.tiny)
        table.cell(dash, 1, 2, str.tostring(distS, "#.#"), text_color=distS < 0.5 ? color.new(colorSup, 0) : color.white, text_size=size.tiny)
    // ATR
    table.cell(dash, 0, 3, "ATR", text_color=color.text_dim, text_size=size.tiny)
    table.cell(dash, 1, 3, str.tostring(atr, "#.##"), text_color=color.white, text_size=size.tiny)
