//@version=5
indicator("Double Dipper Alpha", overlay=true)

// === DOUBLE DIPPER — Entry System ===
// Rules:
// 1. Price at/near a S/R level (within 0.5 ATR)
// 2. Two touches of the level (not exceeding)
// 3. Volume confirmation on second touch
// 4. Entry on close above/below second touch

atrPeriod = input.int(14, "ATR Period", minval=1)
lookback = input.int(20, "Lookback", minval=5)
volMult = input.float(1.2, "Volume Multiplier", step=0.1)

// Find local swings
ph = ta.pivothigh(high, lookback / 2, lookback / 2)
pl = ta.pivotlow(low, lookback / 2, lookback / 2)

// Track double dip patterns
var float ddLevel = na
var int ddTouches = 0
var bool ddActive = false
var int ddBar = na

// Detect level touch
touchLevel(lvl, tolerance) =>
    math.abs(close - lvl) <= tolerance * atr

// Reset on new pattern
if barstate.isnew
    ddActive := false

// Look for swing highs = potential resistance double dip
if not na(ph)
    lvl = ph
    // Check if this level was already touched
    if not na(ddLevel) and math.abs(lvl - ddLevel) < atr * 0.3
        ddTouches += 1
        ddBar := bar_index
    else
        ddLevel := lvl
        ddTouches := 1
        ddActive := true

// Volume check
avgVol = ta.sma(volume, 20)
volConfirm = volume > avgVol * volMult

// Entry signals
longEntry = false
shortEntry = false

// Second touch of support = potential long
if ddTouches >= 2 and volConfirm
    if ddLevel > 0 and close > ddLevel
        longEntry := true
        ddActive := false

// Second touch of resistance = potential short
if ddTouches >= 2 and volConfirm
    if ddLevel > 0 and close < ddLevel
        shortEntry := true
        ddActive := false

// Plot entry signals
plotshape(longEntry, title="Long Entry", style=shape.triangleup, location=location.belowbar, 
          color=color.new(#10b981, 0), size=size.small, text="DD LONG", textcolor=color.new(#10b981, 0))
plotshape(shortEntry, title="Short Entry", style=shape.triangledown, location=location.abovebar, 
          color=color.new(#ef4444, 0), size=size.small, text="DD SHORT", textcolor=color.new(#ef4444, 0))

// Draw the level
plot(ddActive and not na(ddLevel) ? ddLevel : na, title="DD Level", 
     color=color.new(#f59e0b, 30), linewidth=2, style=plot.style_line, extend=extend.right)

// Plot touches
plotshape(ddTouches >= 1 and not na(ddLevel) ? ddLevel : na, title="Touch 1", 
          style=shape.circle, location=location.absolute, color=color.new(#f59e0b, 20), size=size.tiny)
plotshape(ddTouches >= 2 and not na(ddLevel) ? ddLevel : na, title="Touch 2", 
          style=shape.circle, location=location.absolute, color=color.new(#f59e0b, 0), size=size.small)

// Alerts
alertcondition(longEntry, "Double Dip Long", "Double Dipper LONG signal")
alertcondition(shortEntry, "Double Dip Short", "Double Dipper SHORT signal")

// Dashboard
var table dash = table.new(position.top_left, 3, 5, bgcolor=color.new(#0a0e17, 10), border_width=1, frame=true)
if barstate.islast
    table.cell(dash, 0, 0, "DOUBLE DIPP", text_color=color.new(#f59e0b, 0), text_size=size.small, colspan=3)
    table.cell(dash, 0, 1, "Level", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 1, "Touches", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 2, 1, "Status", text_color=color.white, text_size=size.tiny)
    lvlStr = na(ddLevel) ? "—" : str.tostring(ddLevel, "#.##")
    table.cell(dash, 0, 2, lvlStr, text_color=color.new(#f59e0b, 0), text_size=size.tiny)
    table.cell(dash, 1, 2, str.tostring(ddTouches), text_color=ddTouches >= 2 ? color.new(#10b981, 0) : color.white, text_size=size.tiny)
    table.cell(dash, 2, 2, ddActive ? "🟡 ACTIVE" : "⚪", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 0, 3, "ATR", text_color=color.text_dim, text_size=size.tiny)
    table.cell(dash, 1, 3, "Vol Ratio", text_color=color.text_dim, text_size=size.tiny)
    table.cell(dash, 2, 3, "Signal", text_color=color.text_dim, text_size=size.tiny)
    table.cell(dash, 0, 4, str.tostring(ta.sma(ta.tr, atrPeriod), "#.##"), text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 4, str.tostring(volume / avgVol, "#.#"), text_color=volume > avgVol ? color.new(#10b981, 0) : color.white, text_size=size.tiny)
    table.cell(dash, 2, 4, longEntry ? "LONG ↑" : shortEntry ? "SHORT ↓" : "—", 
             text_color=longEntry ? color.new(#10b981, 0) : shortEntry ? color.new(#ef4444, 0) : color.white, text_size=size.tiny)
