//@version=5
indicator("Liquidity Sweep Detector", overlay=true)

// === LIQUIDITY SWEEP INDICATOR ===
// Identifies stop hunts: breaks of swing high/low with sharp rejection

atrPeriod = input.int(14, "ATR Period", minval=1)
swingLen = input.int(10, "Swing Length", minval=5)
rejBars = input.int(2, "Rejection Within (bars)", minval=1, maxval=5)
volThreshold = input.float(1.5, "Volume Spike Multiplier", step=0.1)

// Find swing points
swingHigh_ = ta.pivothigh(high, swingLen, swingLen)
swingLow_ = ta.pivotlow(low, swingLen, swingLen)

var float lastSwingHigh = na
var int lastSwingHighBar = na
var float lastSwingLow = na
var int lastSwingLowBar = na

if not na(swingHigh_)
    lastSwingHigh := swingHigh_
    lastSwingHighBar := bar_index - swingLen

if not na(swingLow_)
    lastSwingLow := swingLow_
    lastSwingLowBar := bar_index - swingLen

atr = ta.atr(atrPeriod)
avgVol = ta.sma(volume, 20)
volRatio = volume / avgVol

// Liquidity Sweep conditions:
// 1. Break above/below recent swing high/low
// 2. Rejection within X candles
// 3. Volume spike on sweep candle

longSweep = false
shortSweep = false

// Long sweep: breaks above swing high, drops back below within X bars
if not na(lastSwingHigh) and bar_index - lastSwingHighBar <= swingLen + rejBars
    if high >= lastSwingHigh and close < lastSwingHigh and volRatio >= volThreshold
        longSweep := true

// Short sweep: breaks below swing low, bounces back above within X bars
if not na(lastSwingLow) and bar_index - lastSwingLowBar <= swingLen + rejBars
    if low <= lastSwingLow and close > lastSwingLow and volRatio >= volThreshold
        shortSweep := true

// Plot sweep markers
plotshape(longSweep, title="Long Sweep", style=shape.labeldown, location=location.abovebar, 
          color=color.new(#ef4444, 0), size=size.small, text="LIQ\nSWEEP", textcolor=color.white)
plotshape(shortSweep, title="Short Sweep", style=shape.labelup, location=location.belowbar, 
          color=color.new(#10b981, 0), size=size.small, text="LIQ\nSWEEP", textcolor=color.white)

// Draw sweep line
var line sweepLine = na
if longSweep or shortSweep
    lvl = longSweep ? lastSwingHigh : lastSwingLow
    linecolor = longSweep ? color.new(#ef4444, 30) : color.new(#10b981, 30)
    if na(sweepLine)
        sweepLine := line.new(bar_index - 5, lvl, bar_index, lvl, color=linecolor, width=1, extend=extend.right)
    else
        line.set_xy1(sweepLine, bar_index - 5, lvl)
        line.set_xy2(sweepLine, bar_index, lvl)
        line.set_color(sweepLine, linecolor)

// Plot recent swing levels
plotshape(not na(swingHigh_), title="Swing High", style=shape.triangledown, location=location.abovebar, 
          color=color.new(#ef4444, 50), size=size.tiny)
plotshape(not na(swingLow_), title="Swing Low", style=shape.triangleup, location=location.belowbar, 
          color=color.new(#10b981, 50), size=size.tiny)

// Alerts
alertcondition(longSweep, "Bullish Liquidity Sweep", "Liquidity sweep detected — shorts stopped out. Look for long setups.")
alertcondition(shortSweep, "Bearish Liquidity Sweep", "Liquidity sweep detected — longs stopped out. Look for short setups.")

// Sweep count
var int sweepCountLong = 0
var int sweepCountShort = 0
var int barOfLastSweep = 0

if longSweep and bar_index != barOfLastSweep
    sweepCountLong += 1
    barOfLastSweep := bar_index
if shortSweep and bar_index != barOfLastSweep
    sweepCountShort += 1
    barOfLastSweep := bar_index

// Dashboard
var table dash = table.new(position.top_right, 3, 5, bgcolor=color.new(#0a0e17, 10), border_width=1)
if barstate.islast
    table.cell(dash, 0, 0, "LIQUIDITY", text_color=color.new(#f59e0b, 0), text_size=size.small, colspan=3)
    table.cell(dash, 0, 1, "Swing High", text_color=color.text_dim, text_size=size.tiny)
    table.cell(dash, 1, 1, "Swing Low", text_color=color.text_dim, text_size=size.tiny)
    table.cell(dash, 2, 1, "Signal", text_color=color.text_dim, text_size=size.tiny)
    
    shStr = na(lastSwingHigh) ? "—" : str.tostring(lastSwingHigh, "#.##")
    slStr = na(lastSwingLow) ? "—" : str.tostring(lastSwingLow, "#.##")
    sigStr = longSweep ? "LONG SWEEP 🔴" : shortSweep ? "SHORT SWEEP 🟢" : "—"
    sigColor = longSweep ? color.new(#ef4444, 0) : shortSweep ? color.new(#10b981, 0) : color.white
    
    table.cell(dash, 0, 2, shStr, text_color=color.new(#ef4444, 30), text_size=size.tiny)
    table.cell(dash, 1, 2, slStr, text_color=color.new(#10b981, 30), text_size=size.tiny)
    table.cell(dash, 2, 2, sigStr, text_color=sigColor, text_size=size.tiny)
    
    table.cell(dash, 0, 3, "Long Sweeps", text_color=color.text_dim, text_size=size.tiny)
    table.cell(dash, 1, 3, "Short Sweeps", text_color=color.text_dim, text_size=size.tiny)
    table.cell(dash, 2, 3, "Vol Ratio", text_color=color.text_dim, text_size=size.tiny)
    table.cell(dash, 0, 4, str.tostring(sweepCountLong), text_color=color.new(#ef4444, 30), text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(sweepCountShort), text_color=color.new(#10b981, 30), text_size=size.small)
    table.cell(dash, 2, 4, str.tostring(volRatio, "#.#") + "x", text_color=volRatio >= volThreshold ? color.new(#f59e0b, 0) : color.white, text_size=size.small)
