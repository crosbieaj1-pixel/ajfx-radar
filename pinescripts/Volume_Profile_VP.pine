//@version=5
indicator("Volume Profile VP", overlay=true, max_boxes_count=500)

// === VOLUME PROFILE ===
// Shows Point of Control (POC) and Value Area on right side of chart

int profiles = input.int(5, "Number of Profiles", minval=1, maxval=20)
int profileHeight = input.int(50, "Profile Height (bars)", minval=20, maxval=200)
float valueAreaPct = input.float(70.0, "Value Area %", step=5, minval=50, maxval=90)

// Colors
pocColor = input.color(color.new(#3b82f6, 0), "POC Color")
vaColor = input.color(color.new(#1e293b, 0), "Value Area Color")
highColor = input.color(color.new(#10b981, 20), "High Volume Zone")
lowColor = input.color(color.new(#ef4444, 20), "Low Volume Zone")

// Build volume profile for each row of price
var float[] profileHighs = array.new_float()
var float[] profileLows = array.new_float()
var float[] profileVols = array.new_float()
var int profileBars = array.new_int()

// Track current bar's volume distribution
var float[] priceVols = array.new_float()
var float minPrice = na
var float maxPrice = na
var int lastBar = 0

// Update on each new bar
if bar_index != lastBar
    lastBar := bar_index
    // Start new profile
    minPrice := low
    maxPrice := high
    priceVols := array.new_float()
    array.push(profileBars, 1)
else
    minPrice := math.min(minPrice, low)
    maxPrice := math.max(maxPrice, high)
    array.push(priceVols, volume)

// On profile close (every profileHeight bars), compute and display
if barstate.islast and array.size(profileBars) >= 1
    rangeSize = maxPrice - minPrice
    if rangeSize > 0 and array.size(priceVols) > 10
        numBuckets = math.min(100, int(rangeSize / ta.sma(tr, 14) * 2))
        bucketSize = rangeSize / numBuckets
        
        float[] vols = array.new_float(size=numBuckets)
        
        // Fill buckets
        for i = 0 to array.size(priceVols) - 1
            if i < bar_index - lastBar + 1
                priceLevel = low[i] + (high[i] - low[i]) / 2
                bucketIdx = int((priceLevel - minPrice) / bucketSize)
                bucketIdx := math.max(0, math.min(numBuckets - 1, bucketIdx))
                array.set(vols, bucketIdx, array.get(vols, bucketIdx) + array.get(priceVols, i))
        
        // Find total volume
        totalVol = 0.0
        for i = 0 to array.size(vols) - 1
            totalVol += array.get(vols, i)
        
        // Find POC (highest volume bucket)
        maxVol = 0.0
        pocIdx = 0
        for i = 0 to array.size(vols) - 1
            if array.get(vols, i) > maxVol
                maxVol := array.get(vols, i)
                pocIdx := i
        
        pocPrice = minPrice + (pocIdx + 0.5) * bucketSize
        pocLine = line.new(bar_index - 10, pocPrice, bar_index, pocPrice, color=pocColor, width=2, extend=extend.right)
        label.new(bar_index - 9, pocPrice, "POC\n" + str.tostring(pocPrice, "#.##"), 
                 style=label.style_label_right, color=pocColor, textcolor=color.white, size=size.small)
        
        // Value Area (top/bottom X% of volume)
        targetVol = totalVol * valueAreaPct / 100
        cumVol = 0.0
        vaHighIdx = pocIdx
        vaLowIdx = pocIdx
        
        // Expand up from POC
        for i = pocIdx + 1 to array.size(vols) - 1
            cumVol += array.get(vols, i)
            if cumVol > targetVol / 2
                vaHighIdx := i
                break
        
        // Expand down from POC
        cumVol := 0.0
        for i = pocIdx - 1 to 0 by -1
            cumVol += array.get(vols, i)
            if cumVol > targetVol / 2
                vaLowIdx := i
                break
        
        vaHighPrice = minPrice + (vaHighIdx + 1) * bucketSize
        vaLowPrice = minPrice + vaLowIdx * bucketSize
        
        // Draw value area box
        vaBox = box.new(bar_index - 5, vaHighPrice, bar_index, vaLowPrice, 
                       bgcolor=vaColor, border_color=color.new(#3b82f6, 50), border_width=1, extend=extend.right)
        
        label.new(bar_index - 4, vaHighPrice, "VAH\n" + str.tostring(vaHighPrice, "#.##"), 
                 style=label.style_label_right, color=color.new(#3b82f6, 50), textcolor=color.white, size=size.tiny)
        label.new(bar_index - 4, vaLowPrice, "VAL\n" + str.tostring(vaLowPrice, "#.##"), 
                 style=label.style_label_right, color=color.new(#3b82f6, 50), textcolor=color.white, size=size.tiny)
        
        // Color bars by volume
        for i = 0 to array.size(vols) - 1
            priceLow = minPrice + i * bucketSize
            priceHigh = priceLow + bucketSize
            barVol = array.get(vols, i)
            volRatio = barVol / maxVol
            barColor = volRatio > 0.7 ? color.new(#10b981, int(60 - volRatio * 40)) :
                       volRatio < 0.3 ? color.new(#ef4444, int(80 - volRatio * 100)) :
                       color.new(#3b82f6, 60)
            barbgcolor(barColor)

// Current price vs POC
cp = close
distToPoc = na(pocPrice) ? na : (cp - pocPrice) / cp * 100

// Dashboard
var table dash = table.new(position.bottom_right, 3, 4, bgcolor=color.new(#0a0e17, 20), border_width=1)
if barstate.islast and not na(pocPrice)
    table.cell(dash, 0, 0, "VOL PROFILE", text_color=color.new(#3b82f6, 0), text_size=size.small, colspan=3)
    table.cell(dash, 0, 1, "POC", text_color=color.text_dim, text_size=size.tiny)
    table.cell(dash, 1, 1, "VAH", text_color=color.text_dim, text_size=size.tiny)
    table.cell(dash, 2, 1, "VAL", text_color=color.text_dim, text_size=size.tiny)
    table.cell(dash, 0, 2, str.tostring(pocPrice, "#.##"), text_color=pocColor, text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(vaHighPrice, "#.##"), text_color=color.white, text_size=size.small)
    table.cell(dash, 2, 2, str.tostring(vaLowPrice, "#.##"), text_color=color.white, text_size=size.small)
    cpColor = not na(distToPoc) and math.abs(distToPoc) < 0.5 ? color.new(#10b981, 0) : color.white
    table.cell(dash, 0, 3, "Price vs POC", text_color=color.text_dim, text_size=size.tiny, colspan=3)
    table.cell(dash, 0, 4, str.tostring(cp, "#.##"), text_color=cpColor, text_size=size.small, colspan=3)
