//@version=5
indicator("Market Scanner Overlay", overlay=true)

// === MULTI-INSTRUMENT SCANNER DASHBOARD ===
// Shows ATR distance, trend, momentum for current chart

atrPeriod = input.int(14, "ATR Period", minval=1)
swingLen = input.int(20, "Swing Length", minval=5)

// Colors
bullColor = color.new(#10b981, 0)
bearColor = color.new(#ef4444, 0)
neutralColor = color.new(#f59e0b, 0)

// ATR
atr = ta.atr(atrPeriod)

// Trend: EMA crossover
emaFast = ta.ema(close, 9)
emaSlow = ta.ema(close, 50)
trend = emaFast > emaSlow ? 1 : emaFast < emaSlow ? -1 : 0

// Momentum
mom5 = ta.mom(close, 5)
mom10 = ta.mom(close, 10)

// ATR distance to nearest swing low
swingLow_ = ta.lowest(low, swingLen)
atrDist = atr > 0 ? (close - swingLow_) / atr : 0

// Composite score
composite = 0.0
if trend == 1: composite += 33
if trend == -1: composite -= 33
if mom5 > 0: composite += 33
if mom5 < 0: composite -= 33

// === TOP LEFT: Scanner Dashboard ===
var table tlDash = table.new(position.top_left, 2, 7, bgcolor=color.new(#0a0e17, 30), border_width=1)
if barstate.islast
    table.cell(tlDash, 0, 0, "MARKET SCANNER", text_color=color.new(#3b82f6, 0), text_size=size.small, colspan=2)
    table.cell(tlDash, 0, 1, "METRIC", text_color=color.text_dim, text_size=size.tiny)
    table.cell(tlDash, 1, 1, "VALUE", text_color=color.text_dim, text_size=size.tiny)
    table.cell(tlDash, 0, 2, "ATR (14)", text_color=color.white, text_size=size.tiny)
    table.cell(tlDash, 1, 2, str.tostring(atr, "#.##"), text_color=color.white, text_size=size.tiny)
    table.cell(tlDash, 0, 3, "ATR Distance", text_color=color.white, text_size=size.tiny)
    table.cell(tlDash, 1, 3, str.tostring(atrDist, "#.#") + "x ATR", 
             text_color=atrDist < 0.5 ? bullColor : atrDist < 1.0 ? neutralColor : color.white, text_size=size.tiny)
    table.cell(tlDash, 0, 4, "Trend (9/50 EMA)", text_color=color.white, text_size=size.tiny)
    table.cell(tlDash, 1, 4, trend == 1 ? "BULLISH ↑" : trend == -1 ? "BEARISH ↓" : "NEUTRAL —",
             text_color=trend == 1 ? bullColor : trend == -1 ? bearColor : neutralColor, text_size=size.tiny)
    table.cell(tlDash, 0, 5, "Momentum (5m)", text_color=color.white, text_size=size.tiny)
    table.cell(tlDash, 1, 5, str.tostring(mom5, "+#;-#;0") + " pts",
             text_color=mom5 > 0 ? bullColor : mom5 < 0 ? bearColor : neutralColor, text_size=size.tiny)
    table.cell(tlDash, 0, 6, "Composite", text_color=color.white, text_size=size.tiny)
    table.cell(tlDash, 1, 6, str.tostring(int(composite)) + "/100",
             text_color=composite > 0 ? bullColor : composite < 0 ? bearColor : neutralColor, text_size=size.tiny)

// === TOP RIGHT: 4-Dot Asset Overview ===
var table trDash = table.new(position.top_right, 4, 3, bgcolor=color.new(#0a0e17, 30), border_width=1)
if barstate.islast
    table.cell(trDash, 0, 0, "NQ", text_color=color.text_dim, text_size=size.tiny)
    table.cell(trDash, 1, 0, "ES", text_color=color.text_dim, text_size=size.tiny)
    table.cell(trDash, 2, 0, "YM", text_color=color.text_dim, text_size=size.tiny)
    table.cell(trDash, 3, 0, "GC", text_color=color.text_dim, text_size=size.tiny)
    // Note: These show current chart signal. For multi-asset use TradingView's screener
    dotColor = composite > 0 ? bullColor : composite < 0 ? bearColor : neutralColor
    table.cell(trDash, 0, 1, "●", text_color=dotColor, text_size=size.large)
    table.cell(trDash, 1, 1, "●", text_color=dotColor, text_size=size.large)
    table.cell(trDash, 2, 1, "●", text_color=dotColor, text_size=size.large)
    table.cell(trDash, 3, 1, "●", text_color=dotColor, text_size=size.large)
    table.cell(trDash, 0, 2, "THIS CHART", text_color=color.text_dim, text_size=size.tiny, colspan=4)

// === BOTTOM LEFT: Momentum Bars ===
var table blDash = table.new(position.bottom_left, 1, 10, bgcolor=color.new(#0a0e17, 30), border_width=0)
if barstate.islast
    table.cell(blDash, 0, 0, "MOM 5m", text_color=color.text_dim, text_size=size.tiny)
    for i = 0 to 8
        offset = 8 - i
        momVal = ta.mom(close[offset], 5)
        barColor = momVal > 0 ? bullColor : momVal < 0 ? bearColor : color.new(#374151, 30)
        barH = math.max(10, math.min(40, math.abs(momVal) * 5))
        table.cell(blDash, 0, i + 1, "▄", text_color=barColor, text_size=size.small)

// Alerts
alertcondition(composite > 50, "Bullish Composite", "Composite score above 50 — bullish momentum")
alertcondition(composite < -50, "Bearish Composite", "Composite score below -50 — bearish momentum")
